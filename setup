#!/usr/bin/env bash
# riskzero-si setup — register skills with Codex or Claude Code
set -euo pipefail

INSTALL_DIR="$(cd "$(dirname "$0")" && pwd)"
HOST=""

usage() {
  cat <<'EOF'
Usage: ./setup [--host codex|claude]

Examples:
  ./setup --host codex
  ./setup --host claude
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --host)
      [ $# -ge 2 ] || {
        echo "Error: --host requires a value" >&2
        usage >&2
        exit 1
      }
      HOST="$2"
      shift 2
      ;;
    --host=*)
      HOST="${1#*=}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Error: unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [ -z "$HOST" ]; then
  case "$INSTALL_DIR" in
    "$HOME/.codex/skills/riskzero-si"*) HOST="codex" ;;
    "$HOME/.claude/skills/riskzero-si"*) HOST="claude" ;;
    *)
      echo "Error: install host를 알 수 없습니다." >&2
      echo "" >&2
      echo "  이 repo를 임의 경로에 clone한 경우 host를 명시해서 실행하세요." >&2
      echo "  예:" >&2
      echo "    ./setup --host codex" >&2
      echo "    ./setup --host claude" >&2
      echo "" >&2
      usage >&2
      exit 1
      ;;
  esac
fi

case "$HOST" in
  codex) SKILLS_DIR="$HOME/.codex/skills" ;;
  claude) SKILLS_DIR="$HOME/.claude/skills" ;;
  *)
    echo "Error: unsupported host '$HOST'. Use codex or claude." >&2
    exit 1
    ;;
esac

RUNTIME_DIR="$SKILLS_DIR/riskzero-si"
GSTACK_DIR="$SKILLS_DIR/gstack"

mkdir -p "$SKILLS_DIR"

echo "riskzero-si setup"
echo "  host: $HOST"
echo "  source dir: $INSTALL_DIR"
echo "  skills dir: $SKILLS_DIR"
echo ""

# 1. gstack 의존성 체크
if [ ! -d "$GSTACK_DIR" ] && [ ! -L "$GSTACK_DIR" ]; then
  echo "Error: gstack이 $SKILLS_DIR 에 설치되어 있지 않습니다." >&2
  echo "" >&2
  echo "  gstack 먼저 설치:" >&2
  echo "  git clone https://github.com/garrytan/gstack.git ~/gstack" >&2
  echo "  cd ~/gstack && ./setup --host $HOST" >&2
  exit 1
fi

echo "  gstack: OK"

# 2. runtime root 연결
if [ "$INSTALL_DIR" != "$RUNTIME_DIR" ]; then
  ln -snf "$INSTALL_DIR" "$RUNTIME_DIR"
  echo "  runtime root: $RUNTIME_DIR -> $INSTALL_DIR"
else
  echo "  runtime root: $RUNTIME_DIR"
fi

# 3. 각 riskzero-si-* 스킬 심링크 생성
linked=()
skipped=()
for skill_dir in "$INSTALL_DIR"/riskzero-si-*/; do
  [ -f "$skill_dir/SKILL.md" ] || continue
  skill_name="$(basename "$skill_dir")"
  target="$SKILLS_DIR/$skill_name"
  if [ -L "$target" ] || [ ! -e "$target" ]; then
    ln -snf "riskzero-si/$skill_name" "$target"
    linked+=("$skill_name")
  else
    skipped+=("$skill_name")
  fi
done

# 4. 기존 qa-checklist 심링크가 있으면 정리 (riskzero-si-qa-checklist로 통합됨)
old_qa="$SKILLS_DIR/qa-checklist"
if [ -L "$old_qa" ]; then
  rm "$old_qa"
  echo "  removed old symlink: qa-checklist (now riskzero-si-qa-checklist)"
fi

echo ""
if [ ${#linked[@]} -gt 0 ]; then
  echo "  linked skills: ${linked[*]}"
fi
if [ ${#skipped[@]} -gt 0 ]; then
  echo "  skipped existing paths: ${skipped[*]}"
fi

echo ""
echo "riskzero-si ready."
echo ""
echo "  사용 가능한 스킬:"
echo "    /riskzero-si-pipeline {기능명}       — 8단계 전체 파이프라인"
echo "    /riskzero-si-plan {기능명}           — Step 1: 구현 계획 수립"
echo "    /riskzero-si-plan-review             — Step 2: 계획 리뷰"
echo "    /riskzero-si-impl {기능명}           — Step 3: FE/BE 코드 구현"
echo "    /riskzero-si-review [경로]           — Step 4: 프로젝트 표준 리뷰"
echo "    /riskzero-si-pr-review               — Step 5: PR diff 리뷰"
echo "    /riskzero-si-qa-checklist {기능명}   — Step 6: QA 체크리스트 생성"
echo "    /riskzero-si-qa [URL]                — Step 7: 버그 조사 + 수정"
echo "    /riskzero-si-browse [URL]            — Step 8: 브라우저 최종 검증"
echo ""
echo "  시작하기:"
echo "    프로젝트 디렉토리에서 /riskzero-si-pipeline --init"
